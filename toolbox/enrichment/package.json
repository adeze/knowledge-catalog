{
  "name": "kcagent",
  "version": "0.1.0",
  "description": "Google Knowledge Catalog Agent",
  "main": "dist/agent/main.js",
  "bin": {
    "kcagent": "./dist/kcagent",
    "md-fileset": "./dist/md-fileset"
  },
  "scripts": {
    "build:lib": "npx tsc -p tsconfig.json",
    "build:agent": "npx bun build --compile --outfile dist/kcagent src/agent/main.ts",
    "build:mdtool": "npx bun build --compile --outfile dist/md-fileset src/tools/md/main.ts",
    "build": "npm run build:lib && npm run build:agent && npm run build:mdtool",
    "compile": "npx tsc --noEmit",
    "debug": "npx adk web src/agent/enrich/agent.ts",
    "run:mdtool": "npm run build:mdtool && npx @modelcontextprotocol/inspector dist/md-fileset --dir root-dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/adk": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "^7.0.0",
    "kcmd": "file:../mdcode"
  },
  "devDependencies": {
    "@google/adk-devtools": "^1.3.0",
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^26.1.0",
    "bun": "^1.3.13",
    "bun-types": "^1.3.13",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@tootallnate/once": "^3.0.1",
    "cacache": "^21.0.1",
    "gaxios": "^7.1.5",
    "googleapis-common": "^8.0.2",
    "http-proxy-agent": "^9.1.0",
    "make-fetch-happen": "^16.0.1",
    "node-gyp": "^13.0.1",
    "sqlite3": "^6.0.1",
    "tar": "^7.5.19",
    "teeny-request": "^10.1.3",
    "uuid": "^14.0.1"
  }
}
